# Required on the Railway worker service (variable references):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   REDIS_URL=${{Redis.REDIS_URL}}
#   (or REDIS_PRIVATE_URL=${{Redis.REDIS_PRIVATE_URL}})
#
# Plus the same S3_* vars as the API.

DATABASE_URL=postgresql://gyotaku:gyotaku@localhost:5432/gyotaku
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=gyotaku
S3_FORCE_PATH_STYLE=true
