generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Upload {
  id         String      @id @default(cuid())
  sessionId  String
  s3Key      String
  imageHash  String      @default("")
  width      Int         @default(0)
  height     Int         @default(0)
  createdAt  DateTime    @default(now())
  renditions Rendition[]

  @@index([sessionId])
  @@index([imageHash])
}

model Rendition {
  id             String          @id @default(cuid())
  uploadId       String
  upload         Upload          @relation(fields: [uploadId], references: [id])
  seed           Int
  styleParams    Json
  status         RenditionStatus @default(QUEUED)
  stage          String?
  matteScore     Float?
  svgKey         String?
  previewKey     String?
  printKey       String?
  estPlotSeconds Int?
  failureReason  String?
  createdAt      DateTime        @default(now())
  completedAt    DateTime?
  orders         Order[]

  @@index([uploadId])
  @@index([status])
  @@unique([uploadId, seed, styleFingerprint])
  styleFingerprint String @default("")
}

enum RenditionStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
  REJECTED
}

model Order {
  id                    String         @id @default(cuid())
  sessionId             String
  renditionId           String
  rendition             Rendition      @relation(fields: [renditionId], references: [id])
  productType           ProductType
  status                OrderStatus    @default(DRAFT)
  /// Amount charged in cents (USD)
  amountCents           Int
  currency              String         @default("usd")
  fishLengthIn          Float?
  email                 String?
  shippingName          String?
  shippingLine1         String?
  shippingLine2         String?
  shippingCity          String?
  shippingState         String?
  shippingPostal        String?
  shippingCountry       String?
  trackingNumber        String?
  stripeCheckoutSession String?        @unique
  stripePaymentIntent   String?
  paidAt                DateTime?
  fulfillmentNote       String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([productType, status])
}

enum ProductType {
  PLOTTED_ORIGINAL
  GICLEE
}

enum OrderStatus {
  DRAFT
  AWAITING_PAYMENT
  PAID
  PLOTTING
  PRINTING
  PACKED
  SHIPPED
  CANCELLED
  REFUNDED
}
