generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Upload {
  id         String      @id @default(cuid())
  sessionId  String
  s3Key      String
  imageHash  String      @default("")
  width      Int         @default(0)
  height     Int         @default(0)
  createdAt  DateTime    @default(now())
  renditions Rendition[]

  @@index([sessionId])
  @@index([imageHash])
}

model Rendition {
  id              String          @id @default(cuid())
  uploadId        String
  upload          Upload          @relation(fields: [uploadId], references: [id])
  seed            Int
  styleParams     Json
  status          RenditionStatus @default(QUEUED)
  stage           String?
  matteScore      Float?
  svgKey          String?
  previewKey      String?
  /// Unwatermarked preview — only exposed after payment
  previewCleanKey String?
  printKey        String?
  estPlotSeconds  Int?
  paperWidthMm    Float?
  paperHeightMm   Float?
  failureReason   String?
  createdAt       DateTime        @default(now())
  completedAt     DateTime?
  orders          Order[]

  @@index([uploadId])
  @@index([status])
  @@unique([uploadId, seed, styleFingerprint])
  styleFingerprint String @default("")
}

enum RenditionStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
  REJECTED
}

model Order {
  id                    String         @id @default(cuid())
  sessionId             String
  renditionId           String
  rendition             Rendition      @relation(fields: [renditionId], references: [id])
  productType           ProductType
  status                OrderStatus    @default(DRAFT)
  /// Total charged in cents (USD) — product + domestic shipping
  amountCents           Int
  /// Length-band SKU e.g. PLOT-M, GIC-L
  sku                   String?
  skuLabel              String?
  /// Prodigi catalog SKU hint e.g. GLOBAL-HGE-16X20
  fulfillmentSku        String?
  /// Product-only cents (excludes shipping)
  productAmountCents    Int?
  /// Flat domestic shipping line item
  shippingCents         Int            @default(0)
  currency              String         @default("usd")
  fishLengthIn          Float?
  /// Optional note for gift packaging
  giftNote              String?
  /// Plotted originals only — e.g. 3 of editionSize
  editionNumber         Int?
  editionSize           Int?
  email                 String?
  /// Captain affiliate who referred this guest (QR ?ref=)
  affiliateId           String?
  affiliate             Affiliate?     @relation(fields: [affiliateId], references: [id])
  /// Captain commission in cents (from product amount)
  commissionCents       Int?
  /// When the operator paid this commission to the captain
  commissionPaidAt      DateTime?
  shippingName          String?
  shippingLine1         String?
  shippingLine2         String?
  shippingCity          String?
  shippingState         String?
  shippingPostal        String?
  shippingCountry       String?
  trackingNumber        String?
  /// Label PDF/PNG URL from EasyPost or Shippo (presigned or provider CDN)
  shippingLabelUrl      String?
  shippingCarrier       String?
  shippingService       String?
  /// Prodigi order id (ord_…) when auto-submitted
  prodigiOrderId        String?        @unique
  /// Last known Prodigi stage (InProgress, Complete, Cancelled, …)
  prodigiStatus         String?
  stripeCheckoutSession String?        @unique
  stripePaymentIntent   String?
  paidAt                DateTime?
  fulfillmentNote       String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([productType, status])
  @@index([affiliateId])
  @@index([prodigiOrderId])
  @@unique([productType, editionNumber])
}

/// Fishing captain (or guide) affiliate — guests scan QR with ?ref=code
model Affiliate {
  id            String   @id @default(cuid())
  /// URL slug for QR links, e.g. capt-mike
  code          String   @unique
  name          String
  email         String?
  boatName      String?
  /// Commission in basis points of product amount (1000 = 10%)
  commissionBps Int      @default(1000)
  active        Boolean  @default(true)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]

  @@index([active])
}

/// Email capture when plotted-original queue is closed
model WaitlistEntry {
  id          String    @id @default(cuid())
  email       String
  sessionId   String?
  renditionId String?
  fishLengthIn Float?
  sku         String?
  productType ProductType @default(PLOTTED_ORIGINAL)
  note        String?
  notifiedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
  @@unique([email, productType])
}

/// Monotonic counter for plotted-original edition numbers
model EditionCounter {
  id   String @id @default("plotted_original")
  next Int    @default(1)
  size Int    @default(25)
}

enum ProductType {
  PLOTTED_ORIGINAL
  GICLEE
  GICLEE_FRAMED
}

enum OrderStatus {
  DRAFT
  AWAITING_PAYMENT
  PAID
  PLOTTING
  PRINTING
  PACKED
  SHIPPED
  CANCELLED
  REFUNDED
}
