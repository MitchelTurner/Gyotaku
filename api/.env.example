DATABASE_URL=postgresql://gyotaku:gyotaku@localhost:5432/gyotaku?schema=public
REDIS_URL=redis://localhost:6379
PORT=3000

# Object storage — browsers PUT photos to the presigned URL, so this must be
# a PUBLIC https endpoint (AWS S3, Cloudflare R2, or MinIO with a public domain).
# localhost:9000 works only on your laptop, not on Railway.
# Local MinIO:
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=gyotaku
S3_PUBLIC_URL=http://localhost:9000/gyotaku
S3_FORCE_PATH_STYLE=true
# Cloudflare R2 (use on BOTH api and worker):
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_BUCKET=gyotaku
# (omit S3_FORCE_PATH_STYLE or set false for R2)
# Optional: if S3_ENDPOINT is private/internal, set the public host for browser URLs:
# S3_BROWSER_ENDPOINT=https://your-bucket.example.com

# CORS: by default the API reflects any Origin. Delete CORS_ORIGINS on Railway
# if you still have localhost:5173 — that was blocking the live web app.
# Only set these if you want a lock-down:
# CORS_STRICT=1
# CORS_ORIGINS=https://gyotaku.up.railway.app
CORS_ORIGINS=

# Phase 3 — Stripe Checkout
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_WEB_URL=http://localhost:5173
OPERATOR_TOKEN=dev-operator-token

# Captain affiliate default commission (basis points; 1000 = 10% of product)
# AFFILIATE_DEFAULT_COMMISSION_BPS=1000

# Plotted-original queue auto-close (ETA in days at PLOTTED_PLOT_HOURS_PER_DAY)
# PLOTTED_QUEUE_MAX_DAYS=14
# PLOTTED_PLOT_HOURS_PER_DAY=4
# PLOTTED_ORDER_OVERHEAD_SECONDS=1800

# Reliability / ops
# QUEUE_DEPTH_ALERT=25
# DEADLETTER_ALERT=5
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERT_WEBHOOK_MIN_INTERVAL_SEC=300

# Shipping labels (EasyPost or Shippo) — used by POST /operator/orders/:id/label
# SHIPPING_PROVIDER=easypost
# EASYPOST_API_KEY=ez_...
# SHIPPO_API_KEY=shippo_...
# SHIP_FROM_NAME=Gyotaku
# SHIP_FROM_LINE1=123 Dock St
# SHIP_FROM_CITY=Seattle
# SHIP_FROM_STATE=WA
# SHIP_FROM_POSTAL=98101
# SHIP_FROM_COUNTRY=US
# SHIP_PARCEL_LENGTH_IN=24
# SHIP_PARCEL_WIDTH_IN=4
# SHIP_PARCEL_HEIGHT_IN=4
# SHIP_PARCEL_WEIGHT_OZ=16

# Length-band SKU pricing (USD cents). Bands: S <14", M <20", L <28", XL 28"+
# PRICE_BAND_S_MAX_IN=14
# PRICE_BAND_M_MAX_IN=20
# PRICE_BAND_L_MAX_IN=28
# Archival print (rolled) — Prodigi-oriented retail
# PRICE_GIC_S_CENTS=4900
# PRICE_GIC_M_CENTS=6900
# PRICE_GIC_L_CENTS=8900
# PRICE_GIC_XL_CENTS=11900
# Framed print
# PRICE_GICF_S_CENTS=9900
# PRICE_GICF_M_CENTS=13900
# PRICE_GICF_L_CENTS=17900
# PRICE_GICF_XL_CENTS=22900
# Shipping by product (US/CA)
# SHIPPING_PRINT_CENTS=900
# SHIPPING_FRAMED_CENTS=1800
# SHIPPING_DOMESTIC_CENTS=1400
# Prodigi print-on-demand (see docs/FULFILLMENT.md)
# PRODIGI_API_KEY=
# PRODIGI_ENV=sandbox
# PRODIGI_AUTO_SUBMIT=true
# PRODIGI_SHIPPING_METHOD=Budget
# PUBLIC_API_URL=https://gyotaku-api.up.railway.app
# INTERNAL_JOB_TOKEN=dev-internal-token
# Worker also needs GYOTAKU_API_URL + INTERNAL_JOB_TOKEN (or OPERATOR_TOKEN)
