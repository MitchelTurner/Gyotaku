DATABASE_URL=postgresql://gyotaku:gyotaku@localhost:5432/gyotaku?schema=public
REDIS_URL=redis://localhost:6379
PORT=3000

# Object storage — browsers PUT photos to the presigned URL, so this must be
# a PUBLIC https endpoint (AWS S3, Cloudflare R2, or MinIO with a public domain).
# localhost:9000 works only on your laptop, not on Railway.
# Local MinIO:
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=gyotaku
S3_PUBLIC_URL=http://localhost:9000/gyotaku
S3_FORCE_PATH_STYLE=true
# Cloudflare R2 (use on BOTH api and worker):
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_BUCKET=gyotaku
# (omit S3_FORCE_PATH_STYLE or set false for R2)
# Optional: if S3_ENDPOINT is private/internal, set the public host for browser URLs:
# S3_BROWSER_ENDPOINT=https://your-bucket.example.com

# CORS: by default the API reflects any Origin. Delete CORS_ORIGINS on Railway
# if you still have localhost:5173 — that was blocking the live web app.
# Only set these if you want a lock-down:
# CORS_STRICT=1
# CORS_ORIGINS=https://gyotaku-web.up.railway.app
CORS_ORIGINS=

# Phase 3 — Stripe Checkout
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PUBLIC_WEB_URL=http://localhost:5173
OPERATOR_TOKEN=dev-operator-token

# Optional price overrides (USD cents)
# PRICE_PLOTTED_BASE_CENTS=12900
# PRICE_PLOTTED_PER_INCH_CENTS=400
# PRICE_PLOTTED_MIN_CENTS=14900
# PRICE_GICLEE_BASE_CENTS=4900
# PRICE_GICLEE_PER_INCH_CENTS=150
# PRICE_GICLEE_MIN_CENTS=5900
