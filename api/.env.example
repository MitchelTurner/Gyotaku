DATABASE_URL=postgresql://gyotaku:gyotaku@localhost:5432/gyotaku?schema=public
REDIS_URL=redis://localhost:6379
PORT=3000

# Object storage — browsers PUT photos to the presigned URL, so this must be
# a PUBLIC https endpoint (AWS S3, Cloudflare R2, or MinIO with a public domain).
# localhost:9000 works only on your laptop, not on Railway.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=gyotaku
S3_PUBLIC_URL=http://localhost:9000/gyotaku
S3_FORCE_PATH_STYLE=true
# Optional: if S3_ENDPOINT is private/internal, set the public host for browser URLs:
# S3_BROWSER_ENDPOINT=https://your-bucket.example.com

# Comma-separated web origins. On Railway set to your web service URL, e.g.
# CORS_ORIGINS=https://web-xxxx.up.railway.app
# Leave empty to allow any origin (fine for early bring-up).
CORS_ORIGINS=http://localhost:5173
